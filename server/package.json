{
  "name": "epic-app",
  "version": "0.0.2",
  "private": true,
  "engines": {
    "node": ">=18 <23",
    "npm": ">=9"
  },
  "scripts": {
    "start": "node -r dotenv/config src/index.js",
    "debug": "nodemon -e ts,js,graphql -x node --inspect -r dotenv/config src/index.js",
    "prod": "node -r dotenv/config src/index.js",
    "playground": "graphql playground --server-only",
    "dev": "nodemon -e js,graphql -x node -r dotenv/config src/index.js",
    "lint": "eslint 'src/**/*.js' 'database/**/*.js' --fix",
    "test": "jest",
    "prisma:deploy": "cd database && prisma1 deploy",
    "prisma:generate": "echo \"Prisma 1 schema is committed at src/generated/prisma.graphql; regenerate with graphql-cli only when datamodel.graphql changes.\"",
    "prisma:pull": "prisma db pull --schema prisma/schema.prisma",
    "prisma:client": "prisma generate --schema prisma/schema.prisma",
    "prestart": "node scripts/verify-generated-prisma.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "apollo-server-express": "^2.26.2",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.7.9",
    "bcryptjs": "2.4.3",
    "bull": "^4.16.5",
    "faker": "^4.1.0",
    "graphql": "^14.6.0",
    "graphql-authentication": "^0.5.5",
    "graphql-authentication-prisma": "^0.1.5",
    "graphql-binding": "^2.5.2",
    "graphql-import": "^1.0.2",
    "graphql-middleware": "^1.6.6",
    "graphql-shield": "^2.2.7",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "moment-timezone": "^0.5.45",
    "ngeohash": "^0.6.3",
    "node-fetch": "^2.7.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.8",
    "offline-geocoder": "^1.0.0",
    "pdfmake": "^0.2.18",
    "prisma": "^6.19.3",
    "prisma-binding": "^2.3.16",
    "prisma1": "^1.34.12",
    "random-weighted-choice": "^0.1.3",
    "rita": "^1.3.85",
    "sharp": "^0.34.5",
    "twitter": "^1.7.1",
    "username-generator": "^1.1.0",
    "uuid": "^11.1.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "eslint": "^5.6.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
