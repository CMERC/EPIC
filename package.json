{
  "name": "epic-vue",
  "version": "2.18.9",
  "private": true,
  "description": "Epic Ready",
  "author": "",
  "scripts": {
    "serve": "npm-run-all --parallel server client",
    "build": "node --max_old_space_size=4096 node_modules/@vue/cli-service/bin/vue-cli-service.js build",
    "lint": "vue-cli-service lint --no-fix",
    "deploy": "cd server/database && node ./migrateWorkspaces.js",
    "client": "vue-cli-service serve --host 0.0.0.0",
    "database": "cd server && npx prisma1 deploy",
    "prod": "npm-run-all build prod:test",
    "prod:test": "http-server ./dist -o",
    "prod:up": "docker compose -f docker-compose.rocky9.yml up -d --build",
    "server": "cd server && npm run dev",
    "staging": "node --max_old_space_size=4096 node_modules/@vue/cli-service/bin/vue-cli-service.js build --mode staging",
    "test:unit": "vue-cli-service test:unit",
    "test:e2e": "vue-cli-service test:e2e --mode serve",
    "prod:down": "docker compose -f docker-compose.rocky9.yml down"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.17",
    "@fortawesome/free-brands-svg-icons": "^5.8.1",
    "@fortawesome/free-regular-svg-icons": "^5.8.1",
    "@fortawesome/free-solid-svg-icons": "^5.8.1",
    "@fullcalendar/core": "^4.2.0",
    "@fullcalendar/daygrid": "^4.2.0",
    "@fullcalendar/interaction": "^4.2.0",
    "@fullcalendar/list": "^4.2.0",
    "@fullcalendar/moment-timezone": "^4.2.0",
    "@fullcalendar/timegrid": "^4.2.0",
    "@fullcalendar/vue": "^4.2.2",
    "apollo-link-retry": "^2.2.15",
    "axios": "^1.7.9",
    "buefy": "^0.8.18",
    "bulma": "^0.9.0",
    "bulma-extensions": "^2.2.1",
    "core-js": "^3.49.0",
    "file-saver": "^2.0.1",
    "jszip": "^3.2.2",
    "milsymbol": "^1.3.3",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.45",
    "ngeohash": "^0.6.3",
    "numeral": "^2.0.6",
    "ol": "^5.2.0",
    "ol-ext": "^3.1.2",
    "olcs": "^2.9.0",
    "plotly.js-dist": "^1.52.3",
    "regenerator-runtime": "^0.14.1",
    "sentiment": "^5.0.1",
    "typedarray": "0.0.6",
    "typeface-open-sans": "0.0.54",
    "typeface-roboto": "0.0.54",
    "vee-validate": "^2.1.0-beta.7",
    "video.js": "^7.21.7",
    "vue": "^2.7.16",
    "vue-apollo": "3.0.3",
    "vue-clipboard2": "^0.3.0",
    "vue-emoji-picker": "^1.0.1",
    "vue-flatpickr-component": "^7.0.5",
    "vue-infinite-scroll": "^2.0.2",
    "vue-multiselect": "^2.1.3",
    "vue-router": "^3.6.5",
    "vue-swatches": "^1.0.2",
    "vuedraggable": "^2.16.0",
    "vuex": "^3.6.2",
    "vuex-persist": "1.8.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "^5.0.8",
    "@vue/cli-plugin-e2e-cypress": "^5.0.8",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-plugin-unit-jest": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/test-utils": "^1.3.6",
    "babel-core": "7.0.0-bridge.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^27.5.1",
    "cache-loader": "^4.1.0",
    "cesium": "^1.48.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^9.33.0",
    "graphql-tag": "^2.12.4",
    "http-server": "^0.11.1",
    "jest-serializer-vue": "^2.0.2",
    "jest-transform-stub": "^2.0.0",
    "lint-staged": "^6.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "1.32.13",
    "sass-loader": "^10.5.2",
    "strip-pragma-loader": "^1.0.0",
    "vue-cli-plugin-apollo": "^0.21.3",
    "vue-cli-plugin-buefy": "^0.2.3",
    "vue-jest": "^3.0.7",
    "vue-template-compiler": "^2.7.16"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not dead"
  ],
  "engines": {
    "node": ">=18 <23",
    "npm": ">=9"
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.js": [
      "vue-cli-service lint",
      "git add"
    ],
    "*.vue": [
      "vue-cli-service lint",
      "git add"
    ]
  }
}
